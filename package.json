{
  "name": "jobsite",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "bunx convex dev --once && concurrently -r \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "bunx convex dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "@convex-dev/react-query": "^0.1.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.3",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.166.14",
    "ai": "^6.0.137",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.33.1",
    "lucide-react": "^1.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "~9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
